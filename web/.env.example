# ── Web Security Suite — variables de entorno ──────────────────
# Copia este archivo como .env y ajusta los valores.
# Nunca subas .env al repositorio.

# Puerto donde se expone el frontend en el host
FRONTEND_PORT=8778

# Origen del frontend para la política CORS de la API
FRONTEND_ORIGIN=http://localhost:8778

# Timeout en segundos por dominio para el scan
SCAN_TIMEOUT_SECONDS=120

# ── Autenticación ───────────────────────────────────────────────
# Usuario admin inicial (se crea solo la primera vez que arranca la app)
APP_FIRST_ADMIN_USER=admin
APP_FIRST_ADMIN_PASSWORD=cambia-esto-antes-de-produccion

# Clave secreta para firmar JWT — genera una con: openssl rand -hex 32
JWT_SECRET=reemplazar-por-valor-largo-y-aleatorio

# Duración de la sesión en minutos (por defecto 8 horas)
JWT_EXPIRE_MINUTES=480
