# ── Web Security Suite — variables de entorno ──────────────────
# Copia este archivo como .env y ajusta los valores.
# Nunca subas .env al repositorio.

# Puerto donde se expone el frontend en el host
FRONTEND_PORT=8778

# Origen del frontend para la política CORS de la API
FRONTEND_ORIGIN=http://localhost:8778

# Timeout en segundos por dominio para el scan
SCAN_TIMEOUT_SECONDS=120
